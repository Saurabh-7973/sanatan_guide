<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ data-extraction policy. We opt OUT of both cloud backup and
  device-to-device transfer for everything in the app's private storage.

  Rationale: the app's only stored state is local-only (bookmarks, notes,
  reading history, settings). It's not synced server-side, so backing it
  up could create stale copies that conflict with the device's live DB.
  Restore is a no-op for a free reinstall — the user's account history is
  on Google Play, not in our app data.
-->
<data-extraction-rules>
  <cloud-backup>
    <exclude domain="root" />
    <exclude domain="file" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
    <exclude domain="external" />
  </cloud-backup>
  <device-transfer>
    <exclude domain="root" />
    <exclude domain="file" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
    <exclude domain="external" />
  </device-transfer>
</data-extraction-rules>
