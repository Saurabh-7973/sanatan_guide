# Sanatan Guide — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# Firebase (configured via firebase_options.dart — these are optional overrides)
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=

# AdMob (only used when building with --dart-define=ADS_ENABLED=true)
NATIVE_AD_UNIT_ID=ca-app-pub-XXXX/YYYY
INTERSTITIAL_AD_UNIT_ID=ca-app-pub-XXXX/YYYY
APP_OPEN_AD_UNIT_ID=ca-app-pub-XXXX/YYYY
